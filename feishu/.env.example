# 飞书应用凭证
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx
FEISHU_BASE_URL=https://open.feishu.cn/open-apis

# 认证凭证类型：tenant（应用级，默认，创建的文档需要复杂路径才能编辑）或 user（用户级，需 OAuth 授权）
# user 模式下，需要使用 OAuth 授权，授权后，用户可以编辑所有文档
FEISHU_AUTH_TYPE=user

# 服务器配置
PORT=3333

# 可选：日志与缓存
LOG_LEVEL=info
CACHE_ENABLED=true
CACHE_TTL=300
